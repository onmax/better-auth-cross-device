{
  "name": "@onmax/cross-device",
  "version": "0.0.0",
  "description": "Better Auth plugin for cross-device authentication flows",
  "homepage": "https://onmax-mini-apps-sdk.onmax.me/reference/packages",
  "bugs": {
    "url": "https://github.com/onmax/nimiq-pay-utils/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/onmax/nimiq-pay-utils.git",
    "directory": "cross-device"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js",
      "default": "./dist/client.js"
    }
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "vp pack",
    "dev": "vp pack --watch",
    "prepack": "pnpm build",
    "check:exports": "publint && attw --pack --profile esm-only",
    "ci": "vp check && vp pack && pnpm check:exports"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.2",
    "better-auth": "^1.6.9",
    "publint": "^0.3.19",
    "vite-plus": "^0.1.20"
  },
  "peerDependencies": {
    "better-auth": ">=1.4.18 <2"
  },
  "packageManager": "pnpm@10.29.2"
}
